# Copy to .env and fill in values
# DB
DB_USER=
DB_PASSWORD=
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=

# Scraper
SCRAPE_YEAR=2026                       # NHL season year for hockey-reference URLs

# Network / SSL
PROJECT_DIR=/home/YOUR_USER/projects/NHLPlayoffPool_dev # Path to your project directory
DUCKDNS_DOMAIN=your-subdomain          # just the subdomain, not .duckdns.org
DUCKDNS_TOKEN=                         # from duckdns.org dashboard
